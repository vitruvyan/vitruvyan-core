# === VSGS (Vitruvyan Semantic Grounding System) ===
# Master feature flag: Enable semantic grounding in LangGraph
VSGS_ENABLED=1

# Top-K semantic matches to retrieve from Qdrant
VSGS_GROUNDING_TOPK=3

# Maximum chars for semantic context in prompt (budget enforcement)
VSGS_PROMPT_BUDGET_CHARS=800

# Store every N grounding events (1=all, 10=every 10th)
VSGS_STORE_EVERY_N=1

# Qdrant collection name for semantic states
VSGS_COLLECTION_NAME=semantic_states

