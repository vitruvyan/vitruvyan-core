services:
  redis:
    image: redis:7.2-alpine
    container_name: omni_redis
    restart: always
    command: redis-server --maxmemory 256mb --maxmemory-policy allkeys-lru --save 60 1
    ports:
      - "9379:6379"
    volumes:
      - redis_data:/data
    networks:
      - vitruvyan_omni_net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 30s
      timeout: 10s
      retries: 3

  keycloak:
    image: quay.io/keycloak/keycloak:24.0.1
    container_name: keycloak
    restart: always
    command:
      - start
      - --proxy=edge
      - --hostname=user.vitruvyan.com
      - --hostname-strict=false
    environment:
      KC_HOSTNAME: user.vitruvyan.com
      KC_HOSTNAME_STRICT: false
      KC_DB: postgres
      KC_DB_URL: jdbc:postgresql://172.17.0.1:5432/keycloak
      KC_DB_USERNAME: vitruvyan_user
      KC_DB_PASSWORD: "@Caravaggio971"
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: "@Caravaggio971"
    ports:
      - "8080:8080"
    networks:
      - vitruvyan_omni_net

  qdrant:
    image: qdrant/qdrant:v1.15.0
    container_name: omni_qdrant
    restart: always
    ports:
      - "9333:6333"
      - "9334:6334"
    volumes:
      - qdrant_data:/qdrant/storage
    networks:
      - vitruvyan_omni_net

  embedding:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_embedding
    container_name: omni_api_embedding
    volumes:
      - .:/app
    networks:
      - vitruvyan_omni_net
    depends_on:
      - qdrant
    ports:
      - "8010:8010"
    restart: unless-stopped
    command: python3 scripts/api_embedding_server.py
    environment:
      - PYTHONPATH=/app
      - QDRANT_URL=http://vitruvyan_qdrant:6333
      - POSTGRES_HOST=${POSTGRES_HOST}
      - POSTGRES_PORT=${POSTGRES_PORT}
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

  # PHASE 1: DEPRECATED - Replaced by Babel Gardens (8009)
  # vitruvyan_api_sentiment:
  #   container_name: omni_sentiment_enhanced
  #   build:
  #     context: .
  #     dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_sentiment
  #   ports:
  #     - "8001:8001"
  #   environment:
  #     # Babel Gardens Integration
  #     - BABEL_GARDENS_EMBEDDING_ENDPOINT=http://vitruvyan_babel_gardens:8009
  #     - BABEL_GARDENS_FUSION_ENABLED=true
  #     - BABEL_GARDENS_FUSION_MODE=enhanced
  #     
  #     # Database connections (aligned with PHASE 2 standardization)
  #     - POSTGRES_HOST=172.17.0.1
  #     - POSTGRES_PORT=5432
  #     - POSTGRES_DB=${POSTGRES_DB}
  #     - POSTGRES_USER=${POSTGRES_USER}
  #     - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
  #   volumes:
  #     - ./core/sentiment:/app/core/sentiment
  #     - ./api_sentiment:/app/api_sentiment
  #     - ./core/logger:/app/core/logger   
  #     - ./core/leo:/app/core/leo
  #     - ./scripts:/app/scripts
  #   depends_on:
  #     - vitruvyan_babel_gardens  # New dependency for sacred linguistic capabilities
  #   restart: unless-stopped
  #   networks:
  #     - vitruvyan-net   

  vitruvyan_api_semantic:
    container_name: omni_api_semantic
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_semantic
    ports:
      - "8002:8002"
    volumes:
      - ./core/logic/semantic_engine.py:/app/core/logic/semantic_engine.py
      - ./core/logic/semantic_modules:/app/core/logic/semantic_modules
    depends_on:
      - qdrant
    networks:
      - vitruvyan_omni_net

  vitruvyan_api_graph:
    build:
      context: ../..
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_graph
    container_name: omni_api_graph
    environment:
      - LANGGRAPH_ENABLED=0
      - DISPATCHER_URL=http://vitruvyan_api:8000/dispatch
      - DISPATCHER_HEALTH_URL=http://vitruvyan_api:8000/health
      - GRAPH_HTTP_TIMEOUT=120
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=vitruvyan
      - POSTGRES_USER=vitruvyan_user
      - POSTGRES_PASSWORD=@Caravaggio971
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      - GRAPH_LLM_MODEL=gpt-4o-mini
      # MCP Integration (Phase 4)
      - USE_MCP=${USE_MCP:-1}
      - MCP_SERVER_URL=http://omni_mcp:8020
      - QDRANT_HOST=vitruvyan_qdrant
      - QDRANT_PORT=6333
      - NE_BASE_URL=http://vitruvyan_api_neural:8003
      - SENTIMENT_API_URL=http://vitruvyan_babel_gardens:8009
      - EMBEDDING_API_URL=http://vitruvyan_api_embedding:8010
      - REDIS_HOST=vitruvyan_redis
      - REDIS_PORT=6379
      - LLM_CACHE_ENABLED=true
      - LLM_CACHE_TTL_HOURS=24
      - LLM_CACHE_MAX_SIZE=10000
      # VSGS (Semantic Grounding) Configuration - PR-C
      - VSGS_ENABLED=${VSGS_ENABLED:-0}
      - VSGS_GROUNDING_TOPK=${VSGS_GROUNDING_TOPK:-3}
      - VSGS_PROMPT_BUDGET_CHARS=${VSGS_PROMPT_BUDGET_CHARS:-800}
      - VSGS_STORE_EVERY_N=${VSGS_STORE_EVERY_N:-1}
    ports:
      - "9004:8004"  # Omni stack uses 9xxx ports to avoid conflict with vitruvyan stack
    restart: unless-stopped
    depends_on:
      - redis
    networks:
      - vitruvyan_omni_net

  vitruvyan_api_neural:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_neural
    container_name: omni_api_neural
    ports:
      - "8003:8003"
    environment:
      PYTHONPATH: /app
      POSTGRES_HOST: 172.17.0.1
      POSTGRES_PORT: 5432
      POSTGRES_DB: vitruvyan
      POSTGRES_USER: vitruvyan_user
      POSTGRES_PASSWORD: "@Caravaggio971"
    volumes:
      # Mount only necessary paths for hot-reload
      - ./docker/services/api_neural_engine:/app/api_neural_engine:ro
      - ./core:/app/core:ro
      - ./.env:/app/.env:ro
    restart: unless-stopped
    networks:
      - vitruvyan_omni_net

  vitruvyan_api_crewai:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_crewai
    container_name: omni_api_crewai
    environment:
      PYTHONPATH: /app
      # PostgreSQL configuration
      POSTGRES_HOST: 172.17.0.1
      POSTGRES_PORT: 5432
      POSTGRES_DB: vitruvyan
      POSTGRES_USER: vitruvyan_user
      POSTGRES_PASSWORD: "@Caravaggio971"
      # Redis Cognitive Bus configuration (PHASE 4.6)
      REDIS_HOST: vitruvyan_redis
      REDIS_PORT: 6379
      # Qdrant configuration (PHASE 4.6)
      QDRANT_HOST: vitruvyan_qdrant
      QDRANT_PORT: 6333
      # OpenAI configuration
      OPENAI_API_KEY: ${OPENAI_API_KEY}
    volumes:
      # Mount only necessary paths for hot-reload
      - ./docker/services/api_crewai:/app/api_crewai:ro
      - ./core:/app/core:ro
    ports:
      - "8005:8005"
    restart: unless-stopped
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - qdrant 

  # 🏛️ ORTHODOXY WARDENS - Sacred Compliance & Divine Order
  vitruvyan_api_orthodoxy_wardens:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.orthodoxy_wardens
    container_name: omni_api_orthodoxy_wardens
    environment:
      PYTHONPATH: /app
      POSTGRES_HOST: 172.17.0.1
      POSTGRES_PORT: 5432
      POSTGRES_DB: vitruvyan
      POSTGRES_USER: vitruvyan_user
      POSTGRES_PASSWORD: "@Caravaggio971"
      OPENAI_API_KEY: ${OPENAI_API_KEY}
      REDIS_HOST: vitruvyan_redis
      REDIS_PORT: 6379
      QDRANT_HOST: vitruvyan_qdrant
      QDRANT_PORT: 6333
      SLACK_WEBHOOK_URL: ${SLACK_WEBHOOK_URL}
      # Sacred Configuration
      ORTHODOXY_MONITORING_INTERVAL: 300
      DIVINE_AUTO_CORRECTION_ENABLED: "true"
      SACRED_COMPLIANCE_THRESHOLD: 0.8
      CONFESSION_AUTO_ABSOLUTION: "false"
    volumes:
      # Mount only API code for hot-reload (NOT entire /app)
      - ./docker/services/api_orthodoxy_wardens:/app/api_orthodoxy_wardens:ro
      - ./core:/app/core:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro  # For sacred Docker operations
    ports:
      - "8006:8006"
    restart: unless-stopped
    depends_on:
      - redis
      - qdrant
      - vitruvyan_api_graph
      - vitruvyan_api_crewai
    networks:
      - vitruvyan_omni_net
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8006/divine-health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s



  # 🛡️ PORTFOLIO GUARDIAN: Financial data protection & market intelligence
  vitruvyan_portfolio_guardian:
    image: vitruvyan-vitruvyan_portfolio_guardian:latest
    container_name: omni_portfolio_guardian
    restart: unless-stopped
    ports:
      - "8011:8011"
    environment:
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      - PORTFOLIO_GUARDIAN_MODE=production
      - GUARDIAN_RISK_THRESHOLD=0.15
      - GUARDIAN_PROTECTION_LEVEL=maximum
      - GUARDIAN_UPDATE_INTERVAL=300
      - GUARDIAN_ALERT_CHANNELS=log,redis
      - AUDIT_ENGINE_URL=http://vitruvyan_api_orthodoxy_wardens:8006
      - CREWAI_AGENTS_URL=http://vitruvyan_api_crewai:8005
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - vitruvyan_api_orthodoxy_wardens      # Integrates with sacred orthodoxy wardens
      # - vitruvyan_vault_keepers   # Integrates with vault keepers (active as vitruvyan_vault_keepers)
      - vitruvyan_api_crewai     # Integrates with CrewAI agents
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8011/guardian/health"]
      interval: 60s
      timeout: 15s
      retries: 3
      start_period: 10s

  # 🌿 Babel Gardens - Sacred Linguistic Unity (Replaces Gemma Cognitive Layer)
  vitruvyan_babel_gardens:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_babel_gardens
    container_name: omni_babel_gardens
    restart: unless-stopped
    ports:
      - "8009:8009"
    environment:
      # Redis Cognitive Bus connection (EPOCH II)
      - REDIS_URL=redis://vitruvyan_redis:6379/0
      - REDIS_HOST=vitruvyan_redis
      - REDIS_PORT=6379
      
      # Database connections (PostgreSQL runs locally on VPS)
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      - QDRANT_URL=http://vitruvyan_qdrant:6333
      
      # Service URLs for sacred bridge module
      - SEMANTIC_ENGINE_URL=http://vitruvyan_api_semantic:8002
      - NEURAL_ENGINE_URL=http://vitruvyan_api_neural:8003
      - CREWAI_URL=http://vitruvyan_api_crewai:8005
      
      # Sacred Model configuration
      - HUGGINGFACE_HUB_CACHE=/app/models
      - TRANSFORMERS_CACHE=/app/models
      - TORCH_HOME=/app/models
      - HUGGINGFACE_HUB_TOKEN=${HUGGINGFACE_HUB_TOKEN}
      
      # Sacred Performance settings
      - CUDA_VISIBLE_DEVICES=
      - OMP_NUM_THREADS=4
      - TOKENIZERS_PARALLELISM=false
      
      # Sacred Logging
      - PYTHONUNBUFFERED=1
      - LOG_LEVEL=INFO
      
    volumes:
      # Sacred Model cache (persistent across restarts)
      - babel_gardens_models:/app/models
      - babel_gardens_logs:/app/logs
      
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - qdrant
      - vitruvyan_api_orthodoxy_wardens      # For sacred integrity reporting
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8009/sacred-health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s          # Allow time for sacred model loading

  # 🕯 Synaptic Conclave Core - Sacred Communication Hub (PHASE 3)
  api_conclave:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_conclave
    container_name: omni_api_conclave
    restart: unless-stopped
    ports:
      - "8012:8012"
    environment:
      # Redis connection for semantic event bus
      - REDIS_URL=redis://vitruvyan_redis:6379/0
      - CONCLAVE_PORT=8012
      
      # Database connections
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      
      # Sacred Order endpoints for routing
      - BABEL_GARDENS_URL=http://vitruvyan_babel_gardens:8009
      - MEMORY_ORDERS_URL=http://vitruvyan_memory_orders:8016
      - ORTHODOXY_WARDENS_URL=http://vitruvyan_api_orthodoxy_wardens:8006
      - VAULT_KEEPERS_URL=http://vitruvyan_vault_keepers:8007
      - SEMANTIC_ENGINE_URL=http://vitruvyan_api_semantic:8002
      - NEURAL_ENGINE_URL=http://vitruvyan_api_neural:8003
      # PHASE 1: Migrated to Babel Gardens unified API
      - SENTIMENT_ENGINE_URL=http://vitruvyan_babel_gardens:8009
      - SENTIMENT_API_URL=http://vitruvyan_babel_gardens:8009
      - CREWAI_URL=http://vitruvyan_api_crewai:8005
      - GRAPH_ORCHESTRATOR_URL=http://vitruvyan_api_graph:8004
      
      # Conclave configuration
      - CONCLAVE_HOST=0.0.0.0
      - CONCLAVE_PORT=8012
      - PULSE_INTERVAL=30
      - LOG_LEVEL=INFO
      - PYTHONUNBUFFERED=1
      
    volumes:
      # Using baked-in code from Dockerfile COPY - no volume mounts
      # - ./core/cognitive_bus:/app/core/cognitive_bus
      # - ./api_conclave:/app/api_conclave
      - ./logs/conclave:/app/logs/conclave
      # - ./utils:/app/utils
      
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - vitruvyan_babel_gardens
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8012/health/conclave"]
      interval: 30s
      timeout: 20s
      retries: 5
      start_period: 30s

  # 🧠 Memory Orders - Dual-Memory System (Archivarium + Mnemosyne) EPOCH II
  vitruvyan_memory_orders:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_memory_orders
    container_name: omni_memory_orders
    restart: unless-stopped
    ports:
      - "8016:8016"
    environment:
      # Redis Cognitive Bus connection (EPOCH II)
      - REDIS_URL=redis://vitruvyan_redis:6379/0
      - REDIS_HOST=vitruvyan_redis
      - REDIS_PORT=6379
      
      # Database connections (Archivarium - PostgreSQL)
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      
      # Vector Database (Mnemosyne - Qdrant)
      - QDRANT_HOST=vitruvyan_qdrant
      - QDRANT_PORT=6333
      - QDRANT_URL=http://vitruvyan_qdrant:6333
      
      # Embedding Service (MiniLM 384-dim)
      - EMBEDDING_SERVICE_URL=http://vitruvyan_api_embedding:8010/embed
      
      # Memory Orders configuration
      - MEMORY_API_HOST=0.0.0.0
      - MEMORY_API_PORT=8016
      - LOG_LEVEL=INFO
      - PYTHONUNBUFFERED=1
      
      # Performance settings
      - MEMORY_WRITE_TIMEOUT=5.0
      - MEMORY_READ_TIMEOUT=3.0
      - MEMORY_VECTOR_TIMEOUT=8.0
      - DUAL_MEMORY_COHERENCE_CHECK=true
      
    volumes:
      - ./core/memory_orders:/app/core/memory_orders
      - ./core/leo:/app/core/leo
      - ./core/cognitive_bus:/app/core/cognitive_bus
      - ./logs/memory_orders:/app/logs/memory_orders
      
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - qdrant
      - embedding
      - vitruvyan_babel_gardens
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8016/health/memory"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

  # 🏰 VAULT KEEPERS - Sacred Memory Custodians & Data Integrity
  vitruvyan_vault_keepers:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.vault_keepers
    container_name: omni_vault_keepers
    restart: unless-stopped
    ports:
      - "8007:8007"
    environment:
      - PYTHONPATH=/app
      # Database connections
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      # Vector DB
      - QDRANT_HOST=vitruvyan_qdrant
      - QDRANT_PORT=6333
      # Redis for Cognitive Bus
      - REDIS_HOST=vitruvyan_redis
      - REDIS_PORT=6379
      # API Configuration
      - VAULT_API_HOST=0.0.0.0
      - VAULT_API_PORT=8007
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      - VAULT_LOG_LEVEL=INFO
    volumes:
      # Mount only API code for hot-reload (NOT entire /app)
      - ./docker/services/api_vault_keepers:/app/api_vault_keepers:ro
      - ./core:/app/core:ro
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - qdrant
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8007/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # 🗝️ CODEX HUNTERS - Discovery & Expedition Management
  vitruvyan_codex_hunters:
    build:
      context: .
      dockerfile: infrastructure/docker/dockerfiles/Dockerfile.api_codex_hunters
    container_name: omni_codex_hunters
    restart: unless-stopped
    ports:
      - "8008:8008"
    environment:
      - PYTHONPATH=/app
      # Database connections
      - POSTGRES_HOST=172.17.0.1
      - POSTGRES_PORT=5432
      - POSTGRES_DB=${POSTGRES_DB}
      - POSTGRES_USER=${POSTGRES_USER}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
      # Vector DB
      - QDRANT_HOST=vitruvyan_qdrant
      - QDRANT_PORT=6333
      # Redis for Cognitive Bus
      - REDIS_HOST=vitruvyan_redis
      - REDIS_PORT=6379
      # API Configuration
      - CODEX_API_HOST=0.0.0.0
      - CODEX_API_PORT=8008
      - OPENAI_API_KEY=${OPENAI_API_KEY}
      - CODEX_LOG_LEVEL=INFO
    # volumes:
    #   - .:/app:ro  # Commented out to use baked-in code with prometheus_client
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis
      - qdrant
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8008/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  # ============================================================
  # MONITORING STACK: Prometheus + Grafana + Exporters
  # ============================================================

  prometheus:
    image: prom/prometheus:latest
    container_name: omni_prometheus
    restart: always
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/usr/share/prometheus/console_libraries'
      - '--web.console.templates=/usr/share/prometheus/consoles'
      - '--storage.tsdb.retention.time=30d'
    ports:
      - "15000:9090"
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./monitoring/alerts:/etc/prometheus/alerts:ro
      - prometheus_data:/prometheus
    networks:
      - vitruvyan_omni_net
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:9090/-/healthy"]
      interval: 30s
      timeout: 10s
      retries: 3

  grafana:
    image: grafana/grafana:latest
    container_name: omni_grafana
    restart: always
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=vitruvyan_admin
      - GF_SERVER_ROOT_URL=https://dash.vitruvyan.com
      - GF_SERVER_DOMAIN=dash.vitruvyan.com
      - GF_INSTALL_PLUGINS=redis-datasource
    ports:
      - "3000:3000"
    volumes:
      - grafana_data:/var/lib/grafana
      - ./monitoring/grafana/provisioning:/etc/grafana/provisioning:ro
    networks:
      - vitruvyan_omni_net
    depends_on:
      - prometheus
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3

  redis_exporter:
    image: oliver006/redis_exporter:latest
    container_name: omni_redis_exporter
    restart: always
    environment:
      - REDIS_ADDR=vitruvyan_redis:6379
    ports:
      - "9121:9121"
    networks:
      - vitruvyan_omni_net
    depends_on:
      - redis

  postgres_exporter:
    image: prometheuscommunity/postgres-exporter:latest
    container_name: omni_postgres_exporter
    restart: always
    environment:
      - DATA_SOURCE_NAME=postgresql://vitruvyan_user:@Caravaggio971@172.17.0.1:5432/vitruvyan?sslmode=disable
      - PG_EXPORTER_EXTEND_QUERY_PATH=/etc/postgres_exporter/queries.yml
    ports:
      - "9187:9187"
    volumes:
      - ./monitoring/postgres_exporter_queries.yml:/etc/postgres_exporter/queries.yml:ro
    networks:
      - vitruvyan_omni_net

