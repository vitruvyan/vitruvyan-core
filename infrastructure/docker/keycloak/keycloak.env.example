## Keycloak local secrets (DO NOT COMMIT)
#
# Copy to `keycloak.env` (gitignored) and fill values.
#
# Used by:
# - `infrastructure/docker/docker-compose.yml` (keycloak + keycloak_db)
# - `infrastructure/docker/keycloak/bootstrap-kb.sh` (realm/client bootstrap)

# Postgres password for the `keycloak_db` container
KC_DB_PASSWORD=CHANGE_ME

# Postgres image expects this variable; set it to the same value as `KC_DB_PASSWORD`
POSTGRES_PASSWORD=CHANGE_ME

# Keycloak admin password for first-time bootstrap/login
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME

# OIDC client secret for client `kb` (used by oauth2-proxy)
KB_OIDC_CLIENT_SECRET=CHANGE_ME
