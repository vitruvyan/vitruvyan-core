# ============================================
# VITRUVYAN CORE - ENVIRONMENT TEMPLATE
# Copy to .env and fill in your values
# ============================================

# === AI/LLM APIs ===
HUGGINGFACE_HUB_TOKEN=hf_your_token_here
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini

# === Translation Agent ===
DEEPSEEK_API_KEY=your_deepseek_key
TRANSLATION_PROVIDER=deepseek
EMBEDDING_API_URL=http://localhost:8010/v1/embeddings/batch

# === PostgreSQL (Docker Container) ===
POSTGRES_HOST=core_postgres
POSTGRES_PORT=5432
POSTGRES_DB=vitruvyan_core
POSTGRES_USER=vitruvyan_core_user
POSTGRES_PASSWORD=change_me_strong_password

# Legacy aliases for compatibility
DB_HOST=${POSTGRES_HOST}
DB_NAME=${POSTGRES_DB}
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# === Redis (Docker Container) ===
REDIS_HOST=core_redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === Qdrant (Docker Container) ===
QDRANT_HOST=core_qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# === Telegram Bot (Optional) ===
TELEGRAM_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id

# === Slack Webhook (Optional) ===
SLACK_WEBHOOK_URL=

# === Reddit (Codex Hunters) ===
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=VitruvyanBot/0.1

# === LangGraph ===
LANGGRAPH_ENABLED=1

# === Internal Services (Docker Network) ===
NE_BASE_URL=http://core_api_neural:8003
SEMANTIC_ENGINE_URL=http://core_api_semantic:8002
GRAPH_API_URL=http://core_api_graph:8004
DISPATCHER_URL=http://core_api_graph:8004/dispatch
DISPATCHER_HEALTH_URL=http://core_api_graph:8004/health

# === Environment Mode ===
VITRUVYAN_ENV=docker
LOG_LEVEL=INFO
ENVIRONMENT=development

# === VSGS (Vitruvyan Semantic Grounding System) ===
VSGS_ENABLED=1
VSGS_GROUNDING_TOPK=3
VSGS_PROMPT_BUDGET_CHARS=800
VSGS_STORE_EVERY_N=1
VSGS_COLLECTION_NAME=semantic_states

# === Security ===
WRITE_KEY=change_me_write_key
ENCRYPTCONTENT_PASSWORD=change_me_encrypt_password
