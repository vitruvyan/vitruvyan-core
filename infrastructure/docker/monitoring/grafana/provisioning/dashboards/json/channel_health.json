{
  "title": "Channel Health — Causal Observability (F3.3)",
  "uid": "channel-health-f33",
  "tags": ["cognitive-system", "channel-health", "observability", "f3.3"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Event Throughput by Channel",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "opacity"
          },
          "color": {"mode": "palette-classic"},
          "unit": "ops"
        }
      },
      "targets": [
        {
          "expr": "rate(scribe_write_total{status=\"success\"}[1m])",
          "legendFormat": "{{stream}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Consumer Lag (Pending Messages)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          },
          "color": {"mode": "palette-classic"},
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 100}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "stream_consumer_lag",
          "legendFormat": "{{stream}} / {{group}} / {{consumer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Dead Letters",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(dead_letter_total) or vector(0)",
          "legendFormat": "Total Dead Letters",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "Dead Letters by Stream",
      "type": "table",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "dead_letter_total",
          "legendFormat": "{{stream}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Write Latency P95 by Stream",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {"mode": "palette-classic"},
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(scribe_write_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 write latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Listener Consumption Latency P95",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {"mode": "palette-classic"},
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(listener_consumption_duration_seconds_bucket[5m]))",
          "legendFormat": "{{stream}} / {{consumer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pending Messages per Stream",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "stream_pending_messages",
          "legendFormat": "{{stream}} / {{group}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 8,
      "title": "Bus Health Score",
      "type": "gauge",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 80}
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "bus_health_score{component=\"overall\"}",
          "legendFormat": "Overall Health",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    }
  ]
}
