      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          },
          "color": {"mode": "palette-classic"},
          "unit": "events/s"
        }
      },
      "targets": [
        {"expr": "sum(rate(stream_length[30s])) by (job)", "legendFormat": "{{job}}", "refId": "A"}
