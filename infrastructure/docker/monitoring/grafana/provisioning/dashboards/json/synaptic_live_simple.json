{
  "title": "Synaptic Conclave LIVE",
  "uid": "synaptic-live",
  "tags": ["live", "neural", "wow"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-5m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "⚡ Live Event Storm — All Streams",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "fillOpacity": 25,
            "gradientMode": "opacity"
          },
          "color": {"mode": "palette-classic"},
          "unit": "events"
        }
      },
      "targets": [{"expr": "topk(12, stream_length)", "legendFormat": "{{stream}}", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "🎯 Sacred Orders Activity — Power Levels",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "events"
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always"
      },
      "targets": [{"expr": "sacred_order_activity", "legendFormat": "{{sacred_order}}", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "💎 Top Streams — Capacity Jewels",
      "type": "stat",
      "gridPos": {"x": 12, "y": 10, "w": 12, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 200}
            ]
          },
          "unit": "events"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "targets": [{"expr": "topk(8, stream_length)", "legendFormat": "{{stream}}", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "🔥 Event Rate Heatmap — Intensity",
      "type": "heatmap",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "options": {
        "calculate": false,
        "cellGap": 2,
        "color": {"mode": "scheme", "scheme": "Spectral"}
      },
      "targets": [{"expr": "cognitive_bus_event_rate", "format": "heatmap", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "⚙️ System Vitals",
      "type": "stat",
      "gridPos": {"x": 12, "y": 20, "w": 6, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      },
      "targets": [
        {"expr": "count(stream_length)", "legendFormat": "Streams", "refId": "A"},
        {"expr": "sum(stream_length)", "legendFormat": "Events", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "📊 Live Ranking",
      "type": "table",
      "gridPos": {"x": 18, "y": 20, "w": 6, "h": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "custom": {"displayMode": "gradient-gauge"},
          "color": {"mode": "continuous-GrYlRd"}
        }
      },
      "targets": [{"expr": "topk(15, stream_length)", "format": "table", "instant": true, "refId": "A"}]
    }
  ]
}
