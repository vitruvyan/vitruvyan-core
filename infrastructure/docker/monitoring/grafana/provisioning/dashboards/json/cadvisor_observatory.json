{
  "title": "🐳 Container Observatory — cAdvisor Live",
  "uid": "cadvisor-observatory",
  "tags": ["containers", "docker", "monitoring", "cadvisor", "sacred-orders"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "💎 Container CPU Usage — Sacred Orders Fleet",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          },
          "color": {"mode": "palette-classic"},
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"core_.*\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "💾 Container Memory Usage — RAM Consumption",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "hue"
          },
          "color": {"mode": "palette-classic"},
          "unit": "bytes",
          "min": 0
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"core_.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "🌐 Network I/O — Traffic Flow",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "color": {"mode": "palette-classic"},
          "unit": "Bps"
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"core_.*\"}[1m])",
          "legendFormat": "RX {{name}}",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"core_.*\"}[1m])",
          "legendFormat": "TX {{name}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "💿 Disk I/O — Storage Activity",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "color": {"mode": "palette-classic"},
          "unit": "Bps"
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}
      },
      "targets": [
        {
          "expr": "rate(container_fs_reads_bytes_total{name=~\"core_.*\"}[1m])",
          "legendFormat": "Read {{name}}",
          "refId": "A"
        },
        {
          "expr": "rate(container_fs_writes_bytes_total{name=~\"core_.*\"}[1m])",
          "legendFormat": "Write {{name}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "📊 Container Resource Overview",
      "type": "table",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "color-background"
          },
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Container"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": []
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"core_.*\"}",
          "format": "table",
          "instant": true,
          "refId": "memory"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"core_.*\"}[1m]) * 100",
          "format": "table",
          "instant": true,
          "refId": "cpu"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "name": 0,
              "Value #memory": 1,
              "Value #cpu": 2
            },
            "renameByName": {
              "name": "Container",
              "Value #memory": "Memory (bytes)",
              "Value #cpu": "CPU (%)"
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "🎯 Top CPU Consumers",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 16, "w": 6, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-GrYlRd"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 90}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {"valueSize": 16}
      },
      "targets": [
        {
          "expr": "topk(10, rate(container_cpu_usage_seconds_total{name=~\"core_.*\"}[1m]) * 100)",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "🏋️ Top Memory Consumers",
      "type": "bargauge",
      "gridPos": {"x": 18, "y": 16, "w": 6, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-BlYlRd"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 524288000},
              {"color": "orange", "value": 1073741824},
              {"color": "red", "value": 2147483648}
            ]
          },
          "unit": "bytes",
          "min": 0
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {"valueSize": 16}
      },
      "targets": [
        {
          "expr": "topk(10, container_memory_usage_bytes{name=~\"core_.*\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "⚡ System Vitals",
      "type": "stat",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 4},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "expr": "count(container_memory_usage_bytes{name=~\"core_.*\"})",
          "legendFormat": "Running Containers",
          "refId": "A"
        },
        {
          "expr": "sum(container_memory_usage_bytes{name=~\"core_.*\"})",
          "legendFormat": "Total Memory Usage",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"core_.*\"}[1m])) * 100",
          "legendFormat": "Total CPU Usage (%)",
          "refId": "C"
        },
        {
          "expr": "sum(rate(container_network_receive_bytes_total{name=~\"core_.*\"}[1m]))",
          "legendFormat": "Network RX (bytes/s)",
          "refId": "D"
        }
      ]
    }
  ]
}
