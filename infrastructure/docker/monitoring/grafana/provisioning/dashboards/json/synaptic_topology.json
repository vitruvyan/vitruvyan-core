          "refId": "A"
        },
        {
          "expr": "sacred_order_activity{sacred_order=\"vault\"}",
          "legendFormat": "vault",
          "refId": "B"
        },
        {
          "expr": "sacred_order_activity{sacred_order=\"orthodoxy\"}",
          "legendFormat": "orthodoxy",
          "refId": "C"
        },
        {
          "expr": "sacred_order_activity{sacred_order=\"babel\"}",
