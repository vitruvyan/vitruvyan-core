{
  "title": "🧠 Synaptic Conclave — Live Neural Activity",
  "uid": "synaptic-conclave-live",
  "tags": ["cognitive-system", "live", "neural-activity", "sacred-orders"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "time": {"from": "now-5m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "⚡ Live Neural Pulse — Event Storm",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 10},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          },
          "color": {"mode": "palette-classic"},
          "unit": "events"
        }
      },
      "targets": [{"expr": "topk(12, stream_length)", "legendFormat": "{{stream}}", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "🎯 Sacred Orders Power Levels — Live Activity",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 10},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3000},
              {"color": "red", "value": 5000}
            ]
          },
          "unit": "events",
          "min": 0,
          "max": 6000
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "text": {"valueSize": 20}
      },
      "targets": [{"expr": "sacred_order_activity", "legendFormat": "{{sacred_order}}", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "💎 Stream Capacity Jewels — Top Streams",
      "type": "stat",
      "gridPos": {"x": 12, "y": 10, "w": 12, "h": 10},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "orange", "value": 1500},
              {"color": "red", "value": 2000}
            ]
          },
          "unit": "events"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value_and_name"
      },
      "targets": [{"expr": "topk(8, stream_length)", "legendFormat": "{{stream}}", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "🔥 Event Rate Heatmap — Publishing Intensity",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 10},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 40,
            "gradientMode": "hue",
            "stacking": {"mode": "normal", "group": "A"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "events/s"
        }
      },
      "targets": [{"expr": "sum(cognitive_bus_event_rate) by (job)", "legendFormat": "{{job}}", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "⚙️ System Vitals — Cognitive Health",
      "type": "stat",
      "gridPos": {"x": 12, "y": 20, "w": 6, "h": 10},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short"
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name"
      },
      "targets": [
        {"expr": "count(stream_length)", "legendFormat": "Streams", "refId": "A"},
        {"expr": "sum(stream_length)", "legendFormat": "Total Events", "refId": "B"},
        {"expr": "sum(sacred_order_activity)", "legendFormat": "Active Events", "refId": "C"}
      ]
    },
    {
      "id": 6,
      "title": "📊 Live Ranking — Top 20 Streams",
      "type": "table",
      "gridPos": {"x": 18, "y": 20, "w": 6, "h": 10},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {"displayMode": "gradient-gauge"},
          "color": {"mode": "continuous-GrYlRd"},
          "unit": "events"
        }
      },
      "targets": [{"expr": "topk(20, stream_length)", "format": "table", "instant": true, "refId": "A"}]
    },
    {
      "id": 7,
      "title": "🌊 Cognitive Flux — Stream Growth Dynamics",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 30, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "stacking": {"mode": "normal"}
          },
          "color": {"mode": "palette-classic"},
          "unit": "events/s"
        }
      },
      "targets": [{"expr": "topk(10, rate(stream_length[30s]))", "legendFormat": "{{stream}}", "refId": "A"}]
    }
  ]
}
