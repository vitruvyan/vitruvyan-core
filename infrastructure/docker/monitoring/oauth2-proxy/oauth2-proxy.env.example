## oauth2-proxy local secrets (DO NOT COMMIT)
#
# Copy to `oauth2-proxy.env` (gitignored) and fill values.
#
# Keep `OAUTH2_PROXY_CLIENT_SECRET` in sync with Keycloak client `kb` secret
# (`KB_OIDC_CLIENT_SECRET` in `infrastructure/docker/keycloak/keycloak.env`).

OAUTH2_PROXY_CLIENT_SECRET=CHANGE_ME

# Must be 16, 24 or 32 bytes (oauth2-proxy counts raw bytes of the string).
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME
