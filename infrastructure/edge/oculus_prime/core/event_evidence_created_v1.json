{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vitruvyan.aicom/schemas/events/evidence_created_v1.json",
  "title": "Vitruvyan Intake Event: evidence.created v1",
  "description": "Event emitted when Evidence Pack is successfully created and persisted",
  "type": "object",
  "required": [
    "event_id",
    "event_version",
    "schema_ref",
    "timestamp_utc",
    "evidence_id",
    "chunk_id",
    "idempotency_key",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^EVT-[0-9A-F]{8}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{12}$",
      "description": "Globally unique event identifier (UUID v4 with EVT prefix)"
    },
    "event_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Event schema version (semver)"
    },
    "schema_ref": {
      "type": "string",
      "const": "vitruvyan://intake/events/evidence_created/v1.0",
      "description": "Canonical schema reference for event validation and replay"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was emitted (UTC)"
    },
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-[0-9A-F]{8}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{12}$",
      "description": "Reference to Evidence Pack ID"
    },
    "chunk_id": {
      "type": "string",
      "pattern": "^CHK-[0-9]+$",
      "description": "Chunk identifier within evidence"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash for idempotent event processing (prevents duplicate handling)"
    },
    "payload": {
      "type": "object",
      "required": ["source_type", "source_uri", "evidence_pack_ref"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["document", "image", "audio", "video", "stream", "sensor"],
          "description": "Media type of ingested evidence"
        },
        "source_uri": {
          "type": "string",
          "description": "Original source location"
        },
        "evidence_pack_ref": {
          "type": "string",
          "description": "Reference to stored Evidence Pack (e.g., postgres row ID or file path)"
        },
        "byte_size": {
          "type": "integer",
          "minimum": 0,
          "description": "Size of evidence in bytes"
        },
        "language_detected": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "ISO 639-1 language code (if applicable)"
        },
        "sampling_policy_ref": {
          "type": "string",
          "description": "Reference to Sampling Policy applied (if any)"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "intake_agent_id": {
          "type": "string",
          "description": "Identifier of intake agent that emitted event (e.g., doc-intake-v1, stream-intake-v1)"
        },
        "intake_agent_version": {
          "type": "string",
          "description": "Version of intake agent"
        },
        "correlation_id": {
          "type": "string",
          "description": "Optional correlation ID for distributed tracing"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retries for this event (for monitoring)"
        }
      }
    }
  },
  "additionalProperties": false
}
