{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vitruvyan.aicom/schemas/evidence_pack_v1.json",
  "title": "Vitruvyan Evidence Pack v1",
  "description": "Immutable, append-only evidence container for pre-epistemic intake",
  "type": "object",
  "required": [
    "evidence_id",
    "chunk_id",
    "schema_version",
    "created_utc",
    "source_ref",
    "normalized_text",
    "technical_metadata",
    "integrity"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EVD-[0-9A-F]{8}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{4}-[0-9A-F]{12}$",
      "description": "Globally unique evidence identifier (UUID v4 with EVD prefix)"
    },
    "chunk_id": {
      "type": "string",
      "pattern": "^CHK-[0-9]+$",
      "description": "Sequential chunk identifier within evidence (CHK-0, CHK-1, ...)"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Evidence Pack schema version (semver)"
    },
    "created_utc": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of evidence pack creation (UTC)"
    },
    "source_ref": {
      "type": "object",
      "required": ["source_type", "source_uri", "source_hash"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["document", "image", "audio", "video", "stream", "sensor"],
          "description": "Media type category"
        },
        "source_uri": {
          "type": "string",
          "description": "Original source location (file path, URL, sensor ID)"
        },
        "source_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of raw source (for immutability verification)"
        },
        "mime_type": {
          "type": "string",
          "description": "MIME type of original source (e.g., application/pdf, image/jpeg)"
        },
        "byte_size": {
          "type": "integer",
          "minimum": 0,
          "description": "Original file size in bytes"
        }
      }
    },
    "normalized_text": {
      "type": "string",
      "description": "DESCRIPTIVE-LITERAL text extracted from source. NO interpretation, NO sentiment, NO domain inference. Empty string allowed for non-textual sources."
    },
    "technical_metadata": {
      "type": "object",
      "description": "Media-specific technical metadata (NOT semantic)",
      "properties": {
        "extraction_method": {
          "type": "string",
          "description": "Tool/library used (e.g., pdfplumber, pytesseract, whisper)"
        },
        "extraction_version": {
          "type": "string",
          "description": "Version of extraction tool"
        },
        "language_detected": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
          "description": "ISO 639-1 language code (e.g., en, it, fr)"
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Extraction confidence (0.0-1.0), NOT semantic relevance"
        },
        "chunk_position": {
          "type": "object",
          "properties": {
            "start_offset": {"type": "integer"},
            "end_offset": {"type": "integer"},
            "total_chunks": {"type": "integer"}
          },
          "description": "Position in multi-chunk evidence"
        },
        "temporal_metadata": {
          "type": "object",
          "properties": {
            "timestamp_start": {"type": "string", "format": "date-time"},
            "timestamp_end": {"type": "string", "format": "date-time"},
            "duration_sec": {"type": "number"}
          },
          "description": "For audio/video/stream sources"
        },
        "spatial_metadata": {
          "type": "object",
          "properties": {
            "latitude": {"type": "number"},
            "longitude": {"type": "number"},
            "altitude_m": {"type": "number"},
            "coordinate_system": {"type": "string"}
          },
          "description": "For geolocated sources (satellite, drones, sensors)"
        }
      }
    },
    "integrity": {
      "type": "object",
      "required": ["evidence_hash", "immutable"],
      "properties": {
        "evidence_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "Hash of (evidence_id + chunk_id + normalized_text + source_hash) for tamper detection"
        },
        "immutable": {
          "type": "boolean",
          "const": true,
          "description": "Evidence Packs are ALWAYS immutable after creation"
        },
        "signature": {
          "type": "string",
          "description": "Optional cryptographic signature (for regulatory compliance)"
        }
      }
    },
    "sampling_policy_ref": {
      "type": "string",
      "description": "Reference to external Sampling Policy (if applicable, e.g., SAMPPOL-STREAM-V1)"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Optional audit tags (e.g., ['critical_infrastructure', 'realtime_feed']) - NOT semantic labels"
    }
  },
  "additionalProperties": false
}
