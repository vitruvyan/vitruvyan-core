#!/usr/bin/env bash
# Vitruvyan Core Update Manager CLI
# Works out-of-the-box without installation

set -e

# Get script directory (vitruvyan-core root)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Setup PYTHONPATH
export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH}"

# Auto-setup completion on first run (if not already configured)
COMPLETION_SETUP_MARKER="${HOME}/.vit_completion_configured"
if [[ ! -f "${COMPLETION_SETUP_MARKER}" ]] && [[ -n "${BASH_VERSION}" ]]; then
    # Check if running interactively
    if [[ $- == *i* ]] && [[ "$1" != "completion" ]]; then
        echo "🎯 Vitruvyan CLI - First time setup"
        echo ""
        echo "Would you like to enable bash autocomplete? (recommended)"
        echo "This will add one line to your ~/.bashrc"
        echo ""
        read -p "Enable autocomplete? [Y/n] " -n 1 -r
        echo ""
        
        if [[ $REPLY =~ ^[Yy]$ ]] || [[ -z $REPLY ]]; then
            # Add completion source to bashrc
            COMPLETION_LINE="source ${SCRIPT_DIR}/vitruvyan_core/core/platform/update_manager/cli/completion/vit-completion.bash"
            
            if ! grep -qF "${COMPLETION_LINE}" "${HOME}/.bashrc" 2>/dev/null; then
                echo "" >> "${HOME}/.bashrc"
                echo "# Vitruvyan CLI autocomplete" >> "${HOME}/.bashrc"
                echo "${COMPLETION_LINE}" >> "${HOME}/.bashrc"
                echo "✅ Autocomplete added to ~/.bashrc"
                echo "   Run: source ~/.bashrc (or restart terminal)"
            else
                echo "✅ Autocomplete already configured in ~/.bashrc"
            fi
            
            # Mark as configured
            touch "${COMPLETION_SETUP_MARKER}"
            echo ""
            echo "Setup complete! Continue with your command..."
            echo ""
        else
            echo "⏭️  Skipping autocomplete setup"
            echo "   You can enable it later by running: vit completion install"
            touch "${COMPLETION_SETUP_MARKER}"
            echo ""
        fi
    fi
fi

# Execute CLI
exec python3 -m vitruvyan_core.core.platform.update_manager.cli.main "$@"
